# Naplace Coin 부스 API. 키는 브라우저 코드에 절대 넣지 마세요.
NAPLACE_COIN_BASE_URL=https://naplace-coin.vercel.app/api/v1
NAPLACE_COIN_API_KEY=

# 결제 추적/게임 토큰 HMAC 서명용. openssl rand -base64 48 등으로 생성
GAME_SIGNING_SECRET=
ENTRY_COIN_PRICE=500
MAX_WAGER_COINS=10000
# Preview/로컬 테스트에서만 true. Production은 false.
ALLOW_TEST_NICKNAME=false

# 실제 싱글 보상 및 승인된 멀티 배팅 정산. coin_settlements SQL 적용 후 Production에서만 true.
# 시작 전 자동 환불은 중복 정산 위험 때문에 관리자 확인 방식으로 유지됩니다.
ALLOW_REAL_REWARDS=false

# 기존 멀티플레이/점수판 설정
SUPABASE_URL=
SUPABASE_ANON_KEY=
# 서버 전용. 절대로 js/ 또는 브라우저 코드에 넣지 마세요.
SUPABASE_SECRET_KEY=
